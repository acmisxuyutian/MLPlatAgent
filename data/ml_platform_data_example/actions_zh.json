[
  {
    "type": "function",
    "function": {
      "name": "add_node",
      "description": "从当前任务可用组件中选择一个组件添加到当前的机器学习工作流中",
      "parameters": {
        "type": "object",
        "properties": {
          "widget_name": {
            "type": "string",
            "description": "组件名称，仅能从当前任务可用组件中选择"
          },
          "node_name": {
            "type": "string",
            "description": "节点名称，需要使用中文名称"
          }
        },
        "required": ["widget_name", "node_name"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "update_node_params",
      "description": "更新当前机器学习工作流中的指定节点的参数信息",
      "parameters": {
        "type": "object",
        "properties": {
          "node_id": {
            "type": "string",
            "description": "节点ID"
          },
          "widget_name": {
            "type": "string",
            "description": "节点所属的组件名称"
          },
          "node_params": {
            "type": "string",
            "description": "节点参数配置，要求输出遵循严格的JSON格式：{\"param1\":\"value1\",\"param2\":\"value2\",...}。参数信息请参考当前任务可用组件中相关组件的介绍"
          }
        },
        "required": ["node_id", "widget_name","node_params"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "add_edge",
      "description": "添加一条边到当前机器学习工作流中",
      "parameters": {
        "type": "object",
        "properties": {
          "source_node_id": {
            "type": "string",
            "description": "节点ID，起始节点ID"
          },
          "target_node_id": {
            "type": "string",
            "description": "节点ID，目标节点ID"
          }
        },
        "required": ["source_node_id", "target_node_id"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "delete_node",
      "description": "删除当前机器学习工作流中的指定节点",
      "parameters": {
        "type": "object",
        "properties": {
          "node_id": {
            "type": "string",
            "description": "节点ID"
          }
        },
        "required": ["node_id"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "delete_edge",
      "description": "删除当前机器学习工作流中的指定边",
      "parameters": {
        "type": "object",
        "properties": {
          "edge_id": {
            "type": "string",
            "description": "边ID"
          }
        },
        "required": ["edge_id"]
      }
    }
  }
]